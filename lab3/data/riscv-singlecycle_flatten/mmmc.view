# FINAL 
# ################

create_constraint_mode -name func -sdc_files "$::env(ENV_DIR)sdc/flatten.sdc"
create_analysis_view -name typ -constraint_mode {func} -delay_corner {typ}
set_analysis_view -setup {typ} -hold {typ}

